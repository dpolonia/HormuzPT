# ─── .env.example ─── TEMPLATE FOR /home/dpolonia/HormuzPT/.env ───
# Copy to .env and fill in real keys
# NEVER commit .env — it is in .gitignore

# Anthropic (claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# OpenAI (gpt-5.4-pro-2026-03-05, gpt-5.4-2026-03-05, gpt-5-mini-2025-08-07)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Google / Vertex AI (gemini-3.1-pro-preview, gemini-3-flash-preview, gemini-3.1-flash-lite-preview)
GOOGLE_CLOUD_PROJECT=hormuzpt
VERTEX_AI_API_KEY=YOUR_KEY_HERE
VERTEX_AI_LOCATION=europe-west1
VERTEX_SA=vertex-express@hormuzpt.iam.gserviceaccount.com

# HuggingFace (meta-llama/Llama-3.1-70B-Instruct)
HUGGINGFACE_API_KEY=hf_YOUR_KEY_HERE

# Scopus (Elsevier)
SCOPUS_API_KEY=YOUR_KEY_HERE

# API Aberta (combustíveis PT)
APIABERTA_API_KEY=YOUR_KEY_HERE

# GCS Cache bucket
GCS_BUCKET=hormuzpt-hormuz-cache

# Environment: development | production
# In development: Intenso tier is never used (automatic downgrade to Moderado)
HORMUZ_ENV=development

# Max weekly cost on LLM APIs (USD)
MAX_WEEKLY_LLM_COST_USD=50
