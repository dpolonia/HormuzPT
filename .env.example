# =========================================================
# HormuzPT - Runtime environment
# =========================================================
HORMUZ_ENV=development

# development | test | production
LLM_DEFAULT_TIER_DEVELOPMENT=baixo
LLM_DEFAULT_TIER_TEST=moderado
LLM_DEFAULT_TIER_PRODUCTION=intenso

# Optional global overrides
LLM_FORCE_TIER=
LLM_FORCE_PROVIDER=
LLM_FORCE_MODEL=

# Router behavior
LLM_ENABLE_FALLBACK=true
LLM_FALLBACK_WITHIN_TIER_FIRST=true
LLM_ALLOW_TIER_DOWNGRADE=true
LLM_ALLOW_TIER_UPGRADE=true

# Cost / latency controls
LLM_LATENCY_SENSITIVE_MODE=true
LLM_BACKOFFICE_COST_SAVING_MODE=true
LLM_ENABLE_RESPONSE_CACHE=true
LLM_ENABLE_REQUEST_DEDUP=true
LLM_MAX_WEEKLY_COST_USD=50
LLM_WARN_AT_PERCENT_BUDGET=80

# Frontend / chat defaults
LLM_FRONTEND_DEFAULT_TIER=moderado
LLM_FRONTEND_SHOW_MODEL=true
LLM_FRONTEND_ALLOW_INTENSO=false

# Backoffice / development defaults
LLM_BACKOFFICE_DEFAULT_TIER=baixo
LLM_DEVELOPMENT_DEFAULT_TIER=baixo
LLM_TEST_DEFAULT_TIER=moderado
LLM_PRODUCTION_DEFAULT_TIER=intenso


# =========================================================
# OpenAI
# =========================================================
OPENAI_API_KEY=your_openai_api_key_here

OPENAI_MODEL_INTENSO=gpt-5.4-pro-2026-03-05
OPENAI_MODEL_MODERADO=gpt-5.4-2026-03-05
OPENAI_MODEL_BAIXO=gpt-5-mini-2025-08-07

# Optional cost metadata
OPENAI_COST_INTENSO_INPUT_USD_PER_1M=30
OPENAI_COST_INTENSO_OUTPUT_USD_PER_1M=180
OPENAI_COST_MODERADO_INPUT_USD_PER_1M=2.5
OPENAI_COST_MODERADO_CACHED_INPUT_USD_PER_1M=0.25
OPENAI_COST_MODERADO_OUTPUT_USD_PER_1M=15
OPENAI_COST_BAIXO_INPUT_USD_PER_1M=0.25
OPENAI_COST_BAIXO_CACHED_INPUT_USD_PER_1M=0.025
OPENAI_COST_BAIXO_OUTPUT_USD_PER_1M=2

# =========================================================
# Anthropic
# =========================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL_INTENSO=claude-opus-4-6
ANTHROPIC_MODEL_MODERADO=claude-sonnet-4-6
ANTHROPIC_MODEL_BAIXO=claude-haiku-4-5

# Optional cost metadata
ANTHROPIC_COST_INTENSO_INPUT_USD_PER_1M=5
ANTHROPIC_COST_INTENSO_OUTPUT_USD_PER_1M=25
ANTHROPIC_COST_MODERADO_INPUT_USD_PER_1M=3
ANTHROPIC_COST_MODERADO_OUTPUT_USD_PER_1M=15
ANTHROPIC_COST_BAIXO_INPUT_USD_PER_1M=1
ANTHROPIC_COST_BAIXO_OUTPUT_USD_PER_1M=5

# =========================================================
# Vertex AI
# =========================================================
VERTEX_AI_API_KEY=your_vertex_api_key_here
GOOGLE_CLOUD_PROJECT=hormuzpt
VERTEX_AI_PROJECT_NUMBER=487878867028
VERTEX_AI_LOCATION=europe-west1
VERTEX_AI_SERVICE_ACCOUNT=vertex-express@hormuzpt.iam.gserviceaccount.com

VERTEX_MODEL_INTENSO=gemini-3.1-pro-preview
VERTEX_MODEL_MODERADO=gemini-3-flash-preview
VERTEX_MODEL_BAIXO=gemini-3.1-flash-lite-preview

# =========================================================
# Routing hints by task class
# =========================================================
LLM_TIER_FRONTEND_QA=moderado
LLM_TIER_BACKOFFICE_ANALYSIS=baixo
LLM_TIER_BACKGROUND_JOBS=baixo
LLM_TIER_RECALIBRATION_DEFAULT=moderado
LLM_TIER_RECALIBRATION_COMPLEX=intenso
LLM_TIER_LONG_CONTEXT_SYNTHESIS=intenso
LLM_TIER_SIMPLE_EXTRACTION=baixo
LLM_TIER_SUMMARIZATION=baixo

# =========================================================
# Safety and observability
# =========================================================
LLM_INCLUDE_MODEL_METADATA_IN_RESPONSE=true
LLM_LOG_ROUTING_DECISIONS=true
LLM_LOG_COST_ESTIMATES=true
LLM_FAIL_FAST_ON_MISSING_PROVIDER=false

# HuggingFace (meta-llama/Llama-3.1-70B-Instruct)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Scopus / Elsevier
SCOPUS_API_KEY=your_scopus_api_key_here

# API Aberta (combustíveis PT)
APIABERTA_API_KEY=your_apiaberta_api_key_here

# GCS Cache bucket
GCS_BUCKET=hormuzpt-hormuz-cache

# Environment: development | test | production
# In development: Intenso tier is only used if escalated explicitly or by high complexity. Low/backoffice tasks stay baixo.
HORMUZ_ENV=development

# Max weekly cost on LLM APIs (USD)
MAX_WEEKLY_LLM_COST_USD=50

# =========================================================
# Private Audit Logging & Email Reporting
# =========================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=hormuzpt@localhost
AUDIT_EMAIL_TO=dpolonia@gmail.com
AUDIT_LOG_DIR=/var/log/hormuzpt/private
AUDIT_EMAIL_TIMEZONE=Europe/Lisbon
